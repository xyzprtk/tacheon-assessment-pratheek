# BigQuery Configuration
BQ_PROJECT_ID="your-gcp-project-id"
BQ_DATASET_ID="crypto_market"
BQ_TABLE_ID="coin_snapshots"

# CoinGecko API Configuration
COINGECKO_API_ENDPOINT="https://api.coingecko.com/api/v3/coins/markets"
COINGECKO_VS_CURRENCY="usd"
COINGECKO_PER_PAGE=100
COINGECKO_MAX_PAGES=3

# Pipeline Configuration
VOLATILITY_THRESHOLD=0.05
LOG_LEVEL="INFO"

# Google Cloud Credentials
# Set this in your shell profile, not in .env
# export GOOGLE_APPLICATION_CREDENTIALS="$HOME/.config/gcloud/bigquery-sa-key.json"
